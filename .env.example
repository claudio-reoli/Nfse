# NFS-e Freire — Variáveis de Ambiente

# Porta do servidor Express
PORT=3099

# Segredo JWT (OBRIGATÓRIO em produção — gere com: openssl rand -hex 32)
JWT_SECRET=

# Ambiente da aplicação (development | production)
NODE_ENV=development

# PostgreSQL (obrigatório)
DATABASE_URL=postgresql://nfse:nfse_dev@localhost:5433/nfse

# Certificado digital do município (.pfx / .p12)
CERT_PATH=
CERT_PASSPHRASE=

# CORS — origens permitidas (separadas por vírgula). Use * apenas em dev.
CORS_ORIGIN=*

# ADN Municípios — override da URL base (opcional)
# ADN_MUN_URL=https://adn.producaorestrita.nfse.gov.br/municipios

# Se a API ADN retornar 404, retornar sucesso com 0 notas em vez de erro (permite usar o sistema com dados locais)
# ADN_SKIP_404=1
